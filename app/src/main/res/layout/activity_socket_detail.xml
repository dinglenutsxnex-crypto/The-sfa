<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_secondary">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_secondary"
            app:titleTextColor="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tv_live_indicator"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⬤ LIVE — data streaming"
                android:textColor="@color/green_active"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:paddingVertical="4dp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tv_conn_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:text="ID: ..." />

            <TextView
                android:id="@+id/tv_protocol"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:layout_marginTop="4dp"
                android:text="Protocol: TCP" />

            <TextView
                android:id="@+id/tv_conn_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:text="Status: ACTIVE" />

            <TextView
                android:id="@+id/tv_traffic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:text="Traffic: ↑0B ↓0B" />

            <androidx.cardview.widget.CardView
                android:id="@+id/card_dns"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:cardBackgroundColor="@color/bg_dns_card"
                app:cardCornerRadius="6dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">
                    <TextView
                        android:id="@+id/tv_dns_query"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/dns_color"
                        android:textSize="12sp"
                        android:fontFamily="monospace"
                        android:text="Query: example.com" />
                    <TextView
                        android:id="@+id/tv_dns_answers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginTop="4dp"
                        android:text="Answers:" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_color" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LIVE DATA STREAM"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:fontFamily="monospace"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        android:background="@color/bg_secondary"
        android:letterSpacing="0.15" />

    <TextView
        android:id="@+id/tv_empty_messages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Waiting for data…"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingVertical="32dp"
        android:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_messages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="8dp" />

</LinearLayout>
