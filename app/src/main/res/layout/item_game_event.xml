<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="#FF0D1117">

    <!-- Colored type indicator bar -->
    <View
        android:id="@+id/view_color_bar"
        android:layout_width="3dp"
        android:layout_height="match_parent"
        android:background="#FF444C56" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="8dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_event_label"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="#FFE6EDF3"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="▲ HANDSHAKE" />

            <TextView
                android:id="@+id/tv_event_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FF444C56"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:text="00:00:00" />

        </LinearLayout>

        <!-- Detail row (hidden when empty) -->
        <TextView
            android:id="@+id/tv_event_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF6E7681"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:text=""
            android:layout_marginTop="2dp"
            android:visibility="gone" />

    </LinearLayout>

</LinearLayout>
