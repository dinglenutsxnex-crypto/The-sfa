<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardBackgroundColor="@color/bg_secondary"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:id="@+id/live_indicator"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/circle_indicator" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_protocol"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:text="TCP"
                android:textColor="@color/bg_primary"
                android:textSize="10sp"
                app:chipMinHeight="24dp" />

            <TextView
                android:id="@+id/tv_address"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:ellipsize="end"
                android:singleLine="true"
                android:text="192.168.1.1:443" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:text="12:00:00" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:text="● active" />

            <TextView
                android:id="@+id/tv_port"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:text="src:12345"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tv_traffic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:text="↑0B ↓0B" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_dns_answer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/dns_color"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:visibility="gone"
            android:text="" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
